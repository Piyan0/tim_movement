[sub_resource type="GDScript" id="GDScript_20bwc"]
script/source = "extends InteractPageSource

func _interact():
    await actions.text([
        \"Shane shane.png Are you alright, sir? You seem uncomfortable.\",
        \"Skoldrax skoldrax.png That’s because I am in pain every hour of the day, young man. This old body is failing me.\",
        \"Skoldrax skoldrax.png Anyone capable of relieving me of this pain will be richly rewarded! Mark my words!\",
    ])

func _item_dropped(item_id):
    if item_id == \"medicine_potion\":
        await actions.text([
            \"Shane shane.png I’m told that this medicinal potion cures all ailments, sir. You might want to try it.\",
            \"Skoldrax skoldrax.png Eureka! For the first time in years my pain is gone! Here, take this golden ring as a reward.\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info golden_ring.png You have obtained a golden ring\"
        ])
        actions.add_item(\"golden_ring\")
        actions.remove_item(\"medicine_potion\")
        actions.add_tag(\"skoldrax_solved\")
    else:
        a.play_sfx(\"unsolved\")
        await actions.text([
            \"Skoldrax skoldrax.png What would I want with that?\",
        ])
"

