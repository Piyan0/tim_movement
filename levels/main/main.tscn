[sub_resource type="GDScript" id="GDScript_eec3g"]
script/source = "extends InteractPageSource

func _interact():
    await actions.text([
        \"Lilian lilian.png Looking for a book, mister? They contain many obscure spells and secret incantations.\",
        \"Shane shane.png Sounds useful. What do you want for that large volume?\",
        \"Lilian lilian.png Bring me something special. A golden ring with a diamond for instance?\",
    ])


func _item_dropped(item_id):
    if item_id == \"golden_ring\":
        actions.remove_item(\"golden_ring\")
        await actions.text([
            \"Shane shane.png I’d love to trade one of your books for this golden ring. Sounds good, huh?\",
            \"Lilian lilian.png Wow! It’s so beautiful! You’ve got yourself a deal, mister.\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info book_of_spell.png You have obtained a book of spells\",
        ])
        actions.add_tag(\"lilian_solved\")
        actions.add_item(\"book_of_spell\")
    else:
        a.play_sfx(\"unsolved\")
        await actions.text([
            \"Lilian lilian.png It looks very pretty, but I think I’ll pass.\"
        ])
"

