[sub_resource type="GDScript" id="GDScript_u4gi4"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Little_Lorx little_lorx.png I wish I could go on an adventure like you. But I don’t own the proper equipment.\",
        \"Shane shane.png Well, I could help you with that. What if I got you a nice travel bag, for instance?\",
        \"Little_Lorx little_lorx.png A travel bag? That would be great! And I’d give you this bottle of mead in return.\",
    ])


func _item_dropped(item_id):
    if item_id == \"travel_bag\":
        a.remove_item()
        await a.text([
            \"Little_Lorx little_lorx.png Wow! Look at how sturdy that travel bag is! Now I can finally go on an adventure!\",
            \"Little_Lorx little_lorx.png Here, take this bottle of mead. It’s fine stuff. And all yours!\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info bottle_of_mead.png You have obtained a bottle of mead\",
        ])
        a.add_item(\"bottle_of_mead\")
        a.add_tag(\"lorx_solved\")
    else:
        a.play_sfx(\"unsolved\")
        await a.text([
            \"Little_Lorx little_lorx.png Not what I was looking for.\",
        ])
"

