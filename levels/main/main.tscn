[sub_resource type="GDScript" id="GDScript_wui37"]
script/source = "extends InteractPageSource


func _interact():
    pass


func _item_dropped(item_id):
    if item_id == \"royal_crystal\":
        a.play_sfx(\"solved\")
        a.play_bgm(\"menu\")
        
        if true:
            var anim = a.find(\"PrincessTransformation\")
            anim.show()
            anim.play(\"main\")
            await anim.animation_finished
        
        await a.text([
            \"Shane shane.png I did it! The princess! She’s alive!\",
            \"Princess_Yontu alice.png Oh, Shane. Words cannot express how grateful I am.\",
            \"Shane shane.png I was simply doing my duty, princess. Think nothing of it.\",
            \"Princess_Yontu alice.png Then continue doing your duty by my side . . . as Prince Shane!\",
        ])
        a.remove_item()
        a.add_tag(\"game_end\")
        await Bootstrap.get_tree().create_timer(1).timeout
        await Bootstrap.fade.fade_in(2)
        var title_screen = load(\"res://ui/main_menu/main_menu.tscn\")
        Bootstrap.get_tree().change_scene_to_packed(title_screen)
        await Bootstrap.fade.fade_out()




func _hover_text():
    if Bootstrap.state.drag_item == \"royal_crystal\":
        return \"Place Crystal\"
    return null
"

