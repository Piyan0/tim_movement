[sub_resource type="GDScript" id="GDScript_q42nm"]
script/source = "extends InteractPageSource

func _interact():
    var text = [
        \"Bonnie bonnie.png Hey! Aren’t you that young hero I’ve heard so much about?\",
        \"Shane shane.png I am indeed. Why, miss? You’re not in trouble I hope?!\",
        \"Bonnie bonnie.png Not at all. I’m just an admirer, that’s all. Here, this might help you fulfil your quest.\",
    ]
    actions.add_item(\"medicine_potion\")
    actions.add_tag(\"bonnie_solved\")
    await actions.text(text)
    
    a.play_sfx(\"solved\")
    await a.text([
        \"Info medicine_potion.png You have obtained a medicinal potion\"
    ])

func _item_dropped(item_id):
    a.play_sfx(\"unsolved\")
    await actions.text([
        \"Bonnie bonnie.png That’s very kind of you, but I don’t need it.\"
    ])
"

