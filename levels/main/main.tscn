[sub_resource type="GDScript" id="GDScript_3lhr6"]
script/source = "extends InteractPageSource

func _interact():
    await actions.text([
        \"Ulli_The_Unlikely ulli.png Salutations! Could you help the great Ulli to become an almighty sorcerer?\",
        \"Shane shane.png I’m not too keen to be honest . . . but go on.\",
        \"Ulli_The_Unlikely ulli.png You scoff, young hero?! Bring Ulli a book of spells and he shall prove himself!\",
    ])
    

func _item_dropped(item_id):
    if item_id == \"book_of_spell\":
        await actions.text([
            \"Ulli_The_Unlikely ulli.png Aha! This book will make Ulli all-powerful! Here is your reward, young hero.\",
            \"Shane shane.png But that’s ... one of the three royal crystals! Thank you, Ulli!\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info royal_crystal.png You have obtained a royal crystal\",
        ])
        actions.add_item(\"royal_crystal\", \"crystal\")
        actions.remove_item()
        actions.add_tag(\"ulli_solved\")
    else:
        a.play_sfx(\"unsolved\")
        await actions.text([
            \"Ulli_The_Unlikely ulli.png Ulli has no use for this.\"
        ])
"

