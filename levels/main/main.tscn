func _interact():
    var shane = \"Shane shane.png %s\"
    var lilian = \"Lilian lilian.png %s\"
    var arr = []
    arr.append( shane % \"Okay cool.\" )
    actions.remove_tag(\"test\")
    await actions.text(arr)

func _item_dropped(item_id):
    pass
    
func _hover_text():
    return super()
"

