[sub_resource type="GDScript" id="GDScript_en4or"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Baltazar baltazar.png I wish to crush my enemies! Could you fetch me a weapon, stranger?\",
        \"Shane shane.png I’m not sure whether that’s such a good idea, sir.\",
        \"Baltazar baltazar.png Bring me an axe and I’ll give you the skull of my last victim. Sounds good, huh?!\",
    ])


func _item_dropped(item_id):
    if item_id == \"axe\":
        await a.text([
            \"Baltazar baltazar.png What a fine axe! That should prove useful. Please except this skull as a reward.\",
            \"Shane shane.png Yuck! It still has hairs on it!\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info human_skull.png You have obtained a human skull\"
        ])
        a.remove_item()
        a.add_item(\"human_skull\")
        a.add_tag(\"baltazar_solved\")
    else:
        a.play_sfx(\"unsolved\")
        await a.text([
            \"Baltazar baltazar.png Are you insulting me, stranger?!\"
        ])
                
"

