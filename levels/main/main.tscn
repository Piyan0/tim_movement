[sub_resource type="GDScript" id="GDScript_yh2qj"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Toby toby.png Hi there! You look like the sort of feller that could use a sturdy travel bag.\",
        \"Shane shane.png That might prove useful. What do you want for it?\",
        \"Toby toby.png Oh, nothing. I’m just glad to finally be rid of it.\",
    ])
    a.play_sfx(\"solved\")
    await a.text([
        \"Info travel_bag.png You have obtained a travel bag\"
    ])
    a.add_item(\"travel_bag\")
    a.add_tag(\"toby_solved\")


func _item_dropped(item_id):
    a.play_sfx(\"unsolved\")
    await a.text([
        \"Toby toby.png No thanks. I’m good.\"
    ])
"

