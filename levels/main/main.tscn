[sub_resource type="GDScript" id="GDScript_uj5r8"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Father_Benjamin father.png Greetings, young man! Would you care to donate to our church?\",
        \"Shane shane.png I’d be glad to, father. Is there anything in particular I could help you with?\",
        \"Father_Benjamin father.png Food, money, gold . . . anything you can spare!\",
    ])


func _item_dropped(item_id):
    if item_id == \"golden_chalice\":
        await a.text([
            \"Shane shane.png Allow me to donate this golden chalice to your church, father.\",
            \"Father_Benjamin father.png This is too much, young man. Thank you! Here, take this royal crystal in return.\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info royal_crystal.png You have obtained a royal crystal\",
        ])
        actions.add_item(\"royal_crystal\", \"crystal\")
        actions.add_tag(\"father_solved\")
        actions.remove_item()
    else:
        a.play_sfx(\"unsolved\")
        await a.text([
            \"Father_Benjamin father.png I cannot accept that, my young friend.\",
        ])

        
"

