[sub_resource type="GDScript" id="GDScript_dga76"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Fiona fiona.png Could you help me find a skull? I need it for my anatomy lessons.\",
        \"Shane shane.png Please tell me you’re studying animals.\",
        \"Fiona fiona.png Humans, I’m afraid. You get me a skull and I’ll reward you handsomely. Trust me.\",
    ])


func _item_dropped(item_id):
    if item_id == \"human_skull\":
        await a.text([
            \"Fiona fiona.png What a beautiful skull! Here, take this. You’ve definitely earned it!\",
            \"Shane shane.png A royal crystal?! Wow! I can’t thank you enough, Fiona!\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info royal_crystal.png You have obtained a royal crystal\"
        ])
        a.remove_item()
        a.add_item(\"royal_crystal\", \"crystal\")
        a.add_tag(\"fiona_solved\")
    else:
        a.play_sfx(\"unsolved\")
        await a.text([
            \"Fiona fiona.png Nope. Not for me, thanks.\"
        ])
"

