[sub_resource type="GDScript" id="GDScript_0fp8q"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Victor victor.png Greetings, young hero. I’ve got a spare axe. Something you’d be interested in?\",
        \"Shane shane.png That should prove useful. What do you want for it?\",
        \"Victor victor.png A weapon for a weapon, my friend. How about you bring me a fine sword?\",
    ])


func _item_dropped(item_id):
    if item_id == \"sword\":
        await a.text([
            \"Shane shane.png Would you be interested in trading this sword for one of your spare axes?\",
            \"Victor victor.png It’s a fine blade indeed! Yes, you’ve got a deal. Thank you, my friend!\",
        ])
        a.play_sfx(\"solved\")
        await a.text([
            \"Info axe.png You have obtained an axe\"
        ])
        a.add_tag(\"victor_solved\")
        a.remove_item()
        a.add_item(\"axe\")
    else:
        a.play_sfx(\"unsolved\")
        await a.text([
            \"Victor victor.png Fine craftsmanship, but not what I was looking for.\"
        ])
"

