[sub_resource type="GDScript" id="GDScript_s50uu"]
script/source = "extends InteractPageSource

func _interact():
    await a.text([
        \"Necros necros.png Fighting has made me tired. I am dying of thirst. Bring me something to drink!\",
        \"Shane shane.png You didn’t say the magic word, you big bully.\",
        \"Necros necros.png Get me a drink! Now! Or else I will keep this golden chalice all to myself!\",
    ])


func _item_dropped(item_id):
    if item_id == \"bottle_of_mead\":
        await a.text([
            \"Shane shane.png Are you willing to trade this bottle of mead for that golden chalice?\",
            \"Necros necros.png My thirst is so great, I’d even trade it for a thousand diamond chalices.\",
        ])
        a.play_sfx(\"solved\")
        await a.text(([
            \"Info golden_chalice.png You have obtained a golden chalice\"
        ]))
        a.remove_item()
        a.add_item(\"golden_chalice\")
        a.add_tag(\"necros_solved\")
    else:
        a.play_sfx(\"unsolved\")
        await a.text([
            \"Necros necros.png Get that thing out of my sight!\"
        ])
"

